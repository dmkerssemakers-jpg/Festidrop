generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("POSTGRES_URL")
}

model Client {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  website       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  events        Event[]
  invoices      Invoice[]
}

model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  accentColor String      @default("#1E8BFF")
  logoUrl     String?
  emailText   String?
  maxPhotos   Int         @default(10)
  isActive    Boolean     @default(true)
  accessCode   String?
  endsAt       DateTime?
  designConfig Json?
  notes        String?
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  drops       Drop[]
  whitelist   Whitelist[]
}

model Drop {
  id      String   @id @default(cuid())
  eventId String
  email   String
  sentAt  DateTime @default(now())
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photos  Photo[]
}

model Photo {
  id        String   @id @default(cuid())
  dropId    String
  drop      Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Whitelist {
  id      String @id @default(cuid())
  eventId String
  email   String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
}

// status: CONCEPT | VERZONDEN | BETAALD | VERLOPEN | GEANNULEERD
model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  status    String        @default("CONCEPT")
  issueDate DateTime      @default(now())
  dueDate   DateTime?
  notes     String?
  vatPct    Float         @default(21)
  lines     InvoiceLine[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  sortOrder   Int     @default(0)
}
